# Required for Motor Cortex (giti build / giti cycle)
ANTHROPIC_API_KEY=

# Optional: OpenClaw integration
OPENCLAW_API_KEY=
OPENCLAW_ENDPOINT=

# Optional: safety controls
GITI_API_BUDGET=100000
GITI_CYCLE_INTERVAL=86400000
GITI_SUPERVISED=true

# Optional: GitHub integration (creates PRs instead of local merges)
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=
GITI_AUTO_MERGE=false
GITI_AUTO_MERGE_DELAY=3600000
